@page
@model FanzinePress.Web.Pages.Admin.Users.CreateModel
@{
    ViewData["Title"] = "Νέος Χρήστης";
}

<h1>Νέος Χρήστης</h1>

<div class="row">
    <div class="col-md-6">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <form method="post">
            <div class="mb-3">
                <label class="form-label" asp-for="Input.Email">Email</label>
                <input type="email" class="form-control" asp-for="Input.Email" required />
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="Input.DisplayName">Όνομα</label>
                <input type="text" class="form-control" asp-for="Input.DisplayName" />
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="Input.Password">Κωδικός</label>
                <input type="password" class="form-control" asp-for="Input.Password" required />
                <small class="text-muted">Τουλάχιστον 8 χαρακτήρες, με τουλάχιστον ένα ψηφίο και ένα μικρό γράμμα.</small>
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="Input.Role">Ρόλος</label>
                <select class="form-select" asp-for="Input.Role">
                    <option value="Editor">Editor</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Δημιουργία</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Άκυρο</a>
        </form>
    </div>
</div>
