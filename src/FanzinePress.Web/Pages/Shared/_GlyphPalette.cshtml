@* Curated retro/newspaper glyph palette *@
<div class="card mb-3">
    <div class="card-header">Γλυφές &amp; Διακοσμητικά</div>
    <div class="card-body p-2">
        <small class="text-muted d-block mb-2">Κάντε κλικ σε ένα πεδίο κειμένου και μετά σε μια γλυφή για εισαγωγή.</small>

        <div class="mb-2">
            <strong class="small">Δείκτες</strong>
            <div class="d-flex flex-wrap gap-1 mt-1">
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="☛" title="Pointing hand right (solid)">☛</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="☞" title="Pointing hand right (outline)">☞</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="☚" title="Pointing hand left (solid)">☚</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="☜" title="Pointing hand left (outline)">☜</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="☝" title="Pointing hand up">☝</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="☟" title="Pointing hand down">☟</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="👉" title="Backhand pointing right">👉</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="👈" title="Backhand pointing left">👈</button>
            </div>
        </div>

        <div class="mb-2">
            <strong class="small">Αστέρια &amp; Σύμβολα</strong>
            <div class="d-flex flex-wrap gap-1 mt-1">
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="★" title="Black star">★</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="☆" title="White star">☆</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✦" title="Black four-pointed star">✦</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✧" title="White four-pointed star">✧</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✪" title="Circled star">✪</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✫" title="Open center star">✫</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✬" title="Black center star">✬</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✯" title="Pinwheel star">✯</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✰" title="Shadowed star">✰</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✡" title="Star of David">✡</button>
            </div>
        </div>

        <div class="mb-2">
            <strong class="small">Διακοσμητικά &amp; Διαχωριστικά</strong>
            <div class="d-flex flex-wrap gap-1 mt-1">
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="❧" title="Rotated floral heart">❧</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="☙" title="Reversed rotated floral heart">☙</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="❦" title="Floral heart">❦</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✠" title="Maltese cross">✠</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✙" title="Greek cross">✙</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✤" title="Heavy Greek cross">✤</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✥" title="Outlined Greek cross">✥</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="❖" title="Diamond">❖</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="◆" title="Black diamond">◆</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="◇" title="White diamond">◇</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="■" title="Black square">■</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="□" title="White square">□</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="●" title="Black circle">●</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="○" title="White circle">○</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="▶" title="Right triangle">▶</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="◀" title="Left triangle">◀</button>
            </div>
        </div>

        <div class="mb-2">
            <strong class="small">Βέλη</strong>
            <div class="d-flex flex-wrap gap-1 mt-1">
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="→" title="Right arrow">→</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="←" title="Left arrow">←</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="↑" title="Up arrow">↑</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="↓" title="Down arrow">↓</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="⇒" title="Double right arrow">⇒</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="⇐" title="Double left arrow">⇐</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="➤" title="Arrowhead right">➤</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="➜" title="Heavy right arrow">➜</button>
            </div>
        </div>

        <div class="mb-2">
            <strong class="small">Ποδόσφαιρο &amp; Σπορ</strong>
            <div class="d-flex flex-wrap gap-1 mt-1">
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="⚽" title="Soccer ball">⚽</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="🏆" title="Trophy">🏆</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="🥇" title="Gold medal">🥇</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="🏟" title="Stadium">🏟</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="🟥" title="Red card">🟥</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="🟨" title="Yellow card">🟨</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="⚑" title="Flag">⚑</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="⚐" title="White flag">⚐</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="🎺" title="Trumpet">🎺</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="🔥" title="Fire">🔥</button>
            </div>
        </div>

        <div class="mb-2">
            <strong class="small">Γραμμές Διαχωρισμού</strong>
            <div class="d-flex flex-wrap gap-1 mt-1">
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="― ✦ ―" title="Star divider">― ✦ ―</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="― ❧ ―" title="Floral divider">― ❧ ―</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="★ ★ ★" title="Three stars">★ ★ ★</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="― ⚽ ―" title="Football divider">― ⚽ ―</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="◆◆◆" title="Diamonds">◆◆◆</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="■ ■ ■" title="Squares">■ ■ ■</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="━━━━━━━━" title="Heavy line">━━━━━</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="─ ─ ─ ─ ─" title="Dashed line">─ ─ ─ ─</button>
            </div>
        </div>

        <div>
            <strong class="small">Πολιτικά &amp; Fanzine</strong>
            <div class="d-flex flex-wrap gap-1 mt-1">
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✊" title="Raised fist">✊</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✌" title="Victory hand">✌</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="☮" title="Peace symbol">☮</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="Ⓐ" title="Circled A">Ⓐ</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="☭" title="Hammer and sickle">☭</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="⚡" title="Lightning">⚡</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✘" title="Heavy X">✘</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✔" title="Check mark">✔</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="✗" title="Ballot X">✗</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="☠" title="Skull and crossbones">☠</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="⚠" title="Warning">⚠</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="📢" title="Loudspeaker">📢</button>
                <button type="button" class="glyph-btn btn btn-outline-dark btn-sm" data-glyph="📰" title="Newspaper">📰</button>
            </div>
        </div>
