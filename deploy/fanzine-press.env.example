# Fanzine Press environment variables.
# Install to /etc/fanzine-press/fanzine-press.env (chmod 600, owned by root).

# ----- Required on first run (creates the admin user) -----
FANZINE_ADMIN_EMAIL=admin@bokontep.gr
FANZINE_ADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# ----- Path base (matches the nginx location) -----
FANZINE_PATH_BASE=/fanzine-press

# ----- Behind reverse proxy: disable in-app HTTPS redirect -----
FANZINE_BEHIND_PROXY=true

# ----- Chromium for PuppeteerSharp (installed by the Dockerfile) -----
FANZINE_CHROMIUM_PATH=/usr/bin/google-chrome

# ----- Data connection -----
ConnectionStrings__DefaultConnection=Data Source=/data/fanzinepress.db

# ----- Runtime knobs -----
ASPNETCORE_ENVIRONMENT=Production
DOTNET_RUNNING_IN_CONTAINER=true
